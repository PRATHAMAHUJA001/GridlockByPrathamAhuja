# Vite environment variables — copy to .env.local for local overrides.
# All variables must be prefixed with VITE_ to be exposed to the browser.

# In production (Vercel), /api/* calls are proxied to the backend via vercel.json rewrites.
# No API URL variable is needed — rewrites handle routing automatically.

# Optional: override the app title shown in the browser tab
# VITE_APP_TITLE=TrafficSarathi
