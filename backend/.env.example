# Copy this file to .env and fill in values before running locally or deploying.

# --- App ---
APP_NAME=TrafficSarathi

# --- Security ---
# Generate a strong random key:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Database ---
# SQLite (default — works locally and on Render with persistent disk)
DATABASE_URL=sqlite:///./traffic_violations.db

# PostgreSQL — uncomment if using Railway / Supabase instead
# DATABASE_URL=postgresql://user:password@host:5432/trafficsarathi

# --- CORS ---
# Comma-separated list of allowed frontend origins.
# Add your production frontend URL once you have it.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://your-app.vercel.app

# --- OCR ---
# Options: easyocr (default, more accurate on CCTV) | tesseract (faster, needs system binary)
TRAFFICSARATHI_OCR_ENGINE=easyocr

# Uncomment to enable slower extra OCR passes for difficult two-line motorcycle plates
# TRAFFICSARATHI_THOROUGH_OCR=1

# --- Detection ---
CONFIDENCE_THRESHOLD=0.35
